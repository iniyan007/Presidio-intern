@@ -480,7 +480,33 @@
 @if (!isPublished) {
     <button class="px-4 py-2 text-primary font-label-md text-label-md" (click)="onSubmit('Draft')" [disabled]="isSubmitting">Save Draft</button>
 }
-<button class="px-6 py-2 bg-secondary-container text-on-secondary-container font-label-md text-label-md rounded-full shadow-sm" (click)="onSubmit('Published')" [disabled]="isSubmitting">Publish</button>
+<button type="button" class="px-6 py-2 bg-secondary-container text-on-secondary-container font-label-md text-label-md rounded-full shadow-sm" (click)="openPublishModal()" [disabled]="isSubmitting">Publish</button>
 </div>
 
+<!-- Publish Confirmation Modal -->
+@if (showPublishModal) {
+    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
+        <div class="bg-surface rounded-2xl shadow-lg max-w-md w-full p-6">
+            <h3 class="text-title-lg font-title-lg text-on-surface mb-4">Confirm Publishing</h3>
+            
+            <p class="text-body-md text-on-surface-variant mb-6">
+                You are about to publish this package. Please note that once a package is published, its basic details (like title, destination, itinerary, etc.) <strong>cannot be edited</strong>. You will only be able to add new seasonal pricing and images.
+            </p>
+            
+            <div class="flex items-start gap-3 mb-8">
+                <input type="checkbox" id="understandCheckbox" [(ngModel)]="publishUnderstandChecked" class="mt-1 w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary">
+                <label for="understandCheckbox" class="text-body-md text-on-surface cursor-pointer select-none">
+                    I understand that published packages cannot be edited.
+                </label>
+            </div>
+            
+            <div class="flex justify-end gap-4">
+                <button type="button" class="px-5 py-2.5 text-primary font-label-md hover:bg-primary/5 rounded-full transition-colors" (click)="closePublishModal()">Cancel</button>
+                <button type="button" class="px-5 py-2.5 bg-primary text-on-primary font-label-md rounded-full hover:bg-primary/90 transition-colors disabled:opacity-50" [disabled]="!publishUnderstandChecked || isSubmitting" (click)="confirmPublish()">
+                    Publish Package
+                </button>
+            </div>
+        </div>
+    </div>
+}
 
